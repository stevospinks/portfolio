{
  "presets": [["react-app", { "flow": false, "typescript": true }]],
  "plugins": [
    "@babel/plugin-proposal-class-properties",
    [
      "module-resolver",
      {
        "root": ["./src/"],
        "alias": {
          "@common": "./common",
          "@components": "./components"
        }
      }
    ]
  ]
}
